# Public — shipped to the browser
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Database (Postgres). Local dev tip: spin one up with `docker run --rm -p 5432:5432 -e POSTGRES_PASSWORD=postgres postgres:16`
DATABASE_URL="postgres://postgres:postgres@localhost:5432/thrybee"

# Resend — get an API key at https://resend.com/api-keys
# In dev you can use Resend's onboarding sender "onboarding@resend.dev" without a verified domain
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="Thrybee <onboarding@resend.dev>"

# Set to 1 to skip env validation during build (CI without secrets)
# SKIP_ENV_VALIDATION=1
