# Public — shipped to the browser
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Convex — shared deployment with the mobile app.
# CONVEX_HTTP_URL is the *.convex.site URL (HTTP actions), NOT the *.convex.cloud client URL.
# Find both in the Convex dashboard or by running `npx convex dev` in the mobile repo.
CONVEX_HTTP_URL="https://your-deployment.convex.site"
# Shared secret for waitlist HTTP actions. Set the same value on the Convex side with:
#   npx convex env set WAITLIST_WEBHOOK_SECRET <value>
CONVEX_WEBHOOK_SECRET="generate-a-long-random-string"

# Resend — get an API key at https://resend.com/api-keys
# In dev you can use Resend's onboarding sender "onboarding@resend.dev" without a verified domain
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="Thrybee <onboarding@resend.dev>"

# Set to 1 to skip env validation during build (CI without secrets)
# SKIP_ENV_VALIDATION=1
